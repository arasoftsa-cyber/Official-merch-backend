# Place this file at: Official-merch-backend/.env
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
JWT_SECRET=your-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
PORT=3000
# Local dev API base: http://localhost:3000
APP_ENV=development
FRONTEND_ORIGIN_DEV=http://localhost:5173
FRONTEND_ORIGIN_PROD=https://yourdomain.com
BACKEND_BASE_URL_DEV=http://localhost:3000
BACKEND_BASE_URL_PROD=https://api.yourdomain.com

# Frontend/public origins
# Canonical OIDC app origin (required in production)
OIDC_APP_BASE_URL=https://officialmerch.tech
# Alias supported by backend origin resolver
APP_PUBLIC_URL=https://officialmerch.tech
CLIENT_URL=https://officialmerch.tech
PASSWORD_RESET_PATH=/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Comma-separated CORS allowlist (no localhost entries in production)
CORS_ORIGINS=https://officialmerch.tech,https://www.officialmerch.tech

# Frontend callback path used after backend completes Google callback
OIDC_APP_CALLBACK_PATH=/auth/oidc/callback

# Google OIDC settings
OIDC_ENABLED=true
OIDC_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
OIDC_CLIENT_ID=your-google-client-id
OIDC_CLIENT_SECRET=your-google-client-secret
OIDC_STATE_SECRET=replace-with-strong-random-secret
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@officialmerch.tech
SENDGRID_FROM_NAME=OfficialMerch
