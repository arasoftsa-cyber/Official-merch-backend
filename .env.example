# Place this file at: Official-merch-backend/.env
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
JWT_SECRET=your-secret-here
JWT_REFRESH_SECRET=replace_with_secure_secret
PORT=3000
APP_ENV=development
MERCH_CURRENCY=INR
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_BASE_URL=http://localhost:3000
ENABLE_MOCK_PAYMENT_MUTATIONS=false
PAYMENTS_WEBHOOK_SECRET=replace-with-strong-random-secret

# Public frontend origin used for OIDC/browser redirects. Required in production.
OIDC_APP_BASE_URL=http://localhost:5173
PASSWORD_RESET_PATH=/reset-password
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Comma-separated CORS allowlist (no localhost entries in production)
CORS_ORIGINS=https://officialmerch.tech,https://www.officialmerch.tech

# Frontend callback path used after backend completes Google callback
OIDC_APP_CALLBACK_PATH=/auth/oidc/callback

# Google OIDC settings
OIDC_ENABLED=true
OIDC_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
OIDC_CLIENT_ID=your-google-client-id
OIDC_CLIENT_SECRET=your-google-client-secret
OIDC_STATE_SECRET=replace-with-strong-random-secret
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@officialmerch.tech
SENDGRID_FROM_NAME=OfficialMerch

# Storage provider selection
# local: app runtime writes/serves from /uploads (default; local/test compatible)
# object: URLs resolve to object-storage/CDN; app /uploads static serving is disabled by default
STORAGE_PROVIDER=local

# Optional compatibility override: keep app /uploads static serving even in object mode
ENABLE_LEGACY_UPLOADS_STATIC=false

# Object storage settings (required only when STORAGE_PROVIDER=object)
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_PREFIX=
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_SESSION_TOKEN=

# Upload scan/status scaffolding
# Default local behavior keeps uploads immediately available.
UPLOAD_SCAN_GATING=false
UPLOAD_SCAN_MODE=immediate
UPLOAD_SCANNER_PROVIDER=noop
